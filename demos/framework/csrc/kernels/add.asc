//csrc/kernels/add.asc
#include "kernel_operator.h"
#include "add.h"

__global__ __vector__ void scalar_vadd(__gm__ uint8_t *A, __gm__ uint8_t *B, __gm__ uint8_t *C, int len)
{
    // serial impl
    // 初始化全局状态寄存器（在TPipe框架编程中，初始化过程由TPipe完成，无需开发者关注；静态Tensor编程方式中需要开发者手动调用）
    AscendC::InitSocState();
    int32_t idx = AscendC::GetBlockIdx();
    int32_t blkNum = AscendC::GetBlockNum();
    uint32_t tileLength = (len + blkNum - 1) / blkNum; // 每个 block 处理的元素数量，向上取整
    __gm__ float *A_gm = (__gm__ float *)A;
    __gm__ float *B_gm = (__gm__ float *)B;
    __gm__ float *C_gm = (__gm__ float *)C;
    for (int i=0;i<tileLength;i++){
        C_gm[i]=A_gm[i]+B_gm[i];
    }
    // if(AscendC::GetBlockIdx() == 0){
    //     AscendC::printf("vadd kernel executed, current block: %d, len=%d\n", AscendC::GetBlockIdx(), len);
    // }
}

__global__ __vector__ void vector_vadd(__gm__ uint8_t *A, __gm__ uint8_t *B, __gm__ uint8_t *C, int len)
{
    // parallel impl
    // 初始化全局状态寄存器（在TPipe框架编程中，初始化过程由TPipe完成，无需开发者关注；静态Tensor编程方式中需要开发者手动调用）
    AscendC::InitSocState();
    int32_t idx = AscendC::GetBlockIdx();
    int32_t blkNum = AscendC::GetBlockNum();
    uint32_t tileLength = (len + blkNum - 1) / blkNum; // 每个 block 处理的元素数量，向上取整

    AscendC::GlobalTensor<float> A_gm;
    A_gm.SetGlobalBuffer((__gm__ float *)A + idx * tileLength, tileLength);
    AscendC::GlobalTensor<float> B_gm;
    B_gm.SetGlobalBuffer((__gm__ float *)B + idx * tileLength, tileLength);
    AscendC::GlobalTensor<float> C_gm;
    C_gm.SetGlobalBuffer((__gm__ float *)C + idx * tileLength, tileLength);

    AscendC::LocalTensor<float> A_vecin(AscendC::TPosition::VECIN,  tileLength * 0 * sizeof(float), tileLength);
    AscendC::LocalTensor<float> B_vecin(AscendC::TPosition::VECIN,  tileLength * 1 * sizeof(float), tileLength);
    AscendC::LocalTensor<float> C_vecin(AscendC::TPosition::VECOUT, tileLength * 2 * sizeof(float), tileLength);
    AscendC::DataCopy<float>(A_vecin, A_gm, tileLength);
    AscendC::DataCopy<float>(B_vecin, B_gm, tileLength);

    AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    AscendC::Add<float>(C_vecin, A_vecin, B_vecin, tileLength);
    AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID1);
    AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID1);

    // AscendC::printf("Block %d processed %d elements, idx %d\n", idx, tileLength, idx * tileLength);
    AscendC::DataCopy<float>(C_gm, C_vecin, tileLength);
}

extern "C" {
    void launch_vector_vadd(aclrtStream stream, int numBlocks, uint8_t *A, uint8_t *B, uint8_t *C, int len)
    {
        vector_vadd<<<numBlocks, nullptr, stream>>>(A, B, C, len);
    }
    void launch_scalar_vadd(aclrtStream stream, int numBlocks, uint8_t *A, uint8_t *B, uint8_t *C, int len)
    {
        scalar_vadd<<<numBlocks, nullptr, stream>>>(A, B, C, len);
    }
}