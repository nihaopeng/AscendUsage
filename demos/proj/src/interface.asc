// 一个Host侧文件，通过<<<>>>异构调用Kernel代码
#include "device.h"
#include "interface.h"

int foo_and_hello(int argc, char *argv[])
{
    int block_num = 4;
    int cachelin_sz = 64;
    uint8_t *out = new uint8_t[block_num * cachelin_sz];
    if (argc >= 3)
    {
        block_num = *argv[0];
        cachelin_sz = *argv[1];
        delete[] out;
        out = (uint8_t*)argv[2];
        printf("block_num:%d,cachelin_sz:%d\n",block_num,cachelin_sz);
    }

    aclInit(nullptr);
    aclrtSetDevice(0);
    aclrtStream stream;
    aclrtCreateStream(&stream);

    uint8_t *OutputValue = nullptr;
    aclrtMalloc((void **)&OutputValue, block_num * cachelin_sz, ACL_MEM_MALLOC_NORMAL_ONLY);

    uint8_t *InitValue = new uint8_t[block_num * cachelin_sz]();
    aclrtMemcpyAsync((void *)OutputValue, block_num * cachelin_sz, InitValue,
                     block_num * cachelin_sz, ACL_MEMCPY_HOST_TO_DEVICE, stream);
    aclrtSynchronizeStream(stream);
    // Invoke a kernel
    launch_foo(block_num,stream,OutputValue,cachelin_sz);
    
    uint8_t *OutHost = nullptr;
    aclrtMallocHost((void **)&OutHost, block_num * cachelin_sz);
    // 异步搬运代码，需要用aclrtSynchronizeStream同步
    aclrtMemcpyAsync(OutHost, block_num * cachelin_sz, OutputValue,
                     block_num * cachelin_sz, ACL_MEMCPY_DEVICE_TO_HOST, stream);
    
    aclrtSynchronizeStream(stream);
    for (int I = 0; I < block_num; I++)
    {
        out[I] = OutHost[I * cachelin_sz];
    }
    
    // Invoke a kernel
    launch_hello_world(block_num,stream,OutputValue,cachelin_sz);
    aclrtSynchronizeStream(stream);

    aclrtFreeHost(OutHost);
    aclrtFree(OutputValue);

    aclrtDestroyStream(stream);
    aclrtResetDevice(0);
    aclFinalize();
    return 0;
}