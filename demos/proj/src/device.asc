#include "device.h"
#include "kernel_operator.h"

__global__ __vector__ void foo(__gm__ uint8_t *Out, int Stride)
{
    Out[block_idx * Stride] = block_idx; // block_idx为内置变量
}
__global__ __cube__ void hello_world(__gm__ uint8_t *Out, int Stride)
{
    int blockNum = AscendC::GetBlockNum();
    int blockIdx = AscendC::GetBlockIdx();
    AscendC::GlobalTensor<uint8_t> gb_out;
    gb_out.SetGlobalBuffer(Out,blockNum);
    AscendC::printf("block[%d/%d]Hello World,test_data%d:%d\n",blockIdx,blockNum,blockIdx,gb_out.GetValue(blockIdx * Stride));
}
extern "C" void launch_foo(int numBlocks, aclrtStream stream, uint8_t *Out, int Stride)
{
    foo<<<numBlocks, nullptr, stream>>>(Out, Stride);
}
extern "C" void launch_hello_world(int numBlocks, aclrtStream stream, uint8_t *Out, int Stride)
{
    hello_world<<<numBlocks, nullptr, stream>>>(Out,Stride);
}