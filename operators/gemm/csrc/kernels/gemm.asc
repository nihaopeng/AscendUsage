//csrc/kernels/add.asc
#include "kernel_operator.h"
#include "gemm.h"
#include "type_traits"

constexpr int32_t QUEUE_DEPTH = 1;
constexpr int32_t CUBE_SIZE = 16;

template <typename Tin, typename Tout>
class KernelMatmul
{
private:
    int32_t DT = 2;

    uint32_t m = 8192;
    uint32_t k = 68416;
    uint32_t n = 256;

    uint32_t L1_m = 0;
    uint32_t L1_k = 0;
    uint32_t L1_n = 0;

    uint32_t L2_m = 0;
    uint32_t L2_k = 0;
    uint32_t L2_n = 0;

    uint32_t process_id = 0;
    uint32_t process_num = 0;

    uint32_t a_group_num = 0;
    uint32_t b_group_num = 0;
    uint32_t group_num = 0;
    uint32_t group_per_core = 0;

    bool is_new_group = true;

    AscendC::TPipe pipe;

    AscendC::TQue<AscendC::TPosition::A1, QUEUE_DEPTH> inQueueA1;
    AscendC::TQue<AscendC::TPosition::A2, QUEUE_DEPTH> inQueueA2;
    AscendC::TQue<AscendC::TPosition::B1, QUEUE_DEPTH> inQueueB1;
    AscendC::TQue<AscendC::TPosition::B2, QUEUE_DEPTH> inQueueB2;
    // TQue<QuePosition::VECOUT, 1> csr_dense_VEC;
    // dst queue
    AscendC::TQue<AscendC::TPosition::CO1, QUEUE_DEPTH> outQueueCO1;
    AscendC::TQue<AscendC::TPosition::CO2, QUEUE_DEPTH> outQueueCO2;

    AscendC::GlobalTensor<Tin> aGM, bGM;
    AscendC::GlobalTensor<Tout> cGM;

public:
    __aicore__ inline KernelMatmul()
    {
    }
    __aicore__ inline void Init(GM_ADDR a, GM_ADDR b, GM_ADDR c, int32_t M, int32_t N, int32_t K,
                                int32_t L1_m, int32_t L1_k, int32_t L1_n,
                                int32_t L2_m, int32_t L2_k, int32_t L2_n, int32_t buffer_num)
    {   
        if constexpr (AscendC::Std::is_same<Tin,bfloat16_t>::value){
            this->DT = 2;
        }else if constexpr (AscendC::Std::is_same<Tin,int8_t>::value){
            this->DT = 1;
        }else if constexpr (AscendC::Std::is_same<Tin,half>::value){
            this->DT = 2;
        }

        this->m = M;
        this->n = N;
        this->k = K;

        this->L1_m = L1_m;
        this->L1_k = L1_k;
        this->L1_n = L1_n;
        this->L2_m = L2_m;
        this->L2_k = L2_k;
        this->L2_n = L2_n;

        this->process_id = AscendC::GetBlockIdx();
        this->process_num = AscendC::GetBlockNum();

        // 以块为单位的行列总乘积，用来划分aicore的任务。
        this->a_group_num = this->CalcBlockNum(m, L1_m);
        this->b_group_num = this->CalcBlockNum(n, L1_n);
        this->group_num = this->a_group_num * this->b_group_num;
        this->group_per_core = this->group_num / this->process_num;
        // if(this->process_id==0){
        //     AscendC::printf("a_group_num: %d, b_group_num: %d, group_num: %d, group_per_core: %d", 
        //         this->a_group_num, this->b_group_num, this->group_num, this->group_per_core);
        // }

        aGM.SetGlobalBuffer((__gm__ Tin *)a);
        bGM.SetGlobalBuffer((__gm__ Tin *)b);
        cGM.SetGlobalBuffer((__gm__ Tout *)c);

        // L1 size=1048576
        pipe.InitBuffer(inQueueA1, buffer_num, L1_m * L1_k * sizeof(Tin)); //(1048576÷2)÷2÷2=256*512
        pipe.InitBuffer(inQueueB1, buffer_num, L1_k * L1_n * sizeof(Tin)); //(1048576÷2)÷2÷2=256*512

        // L2 a size=65536,L2 b size=65536
        pipe.InitBuffer(inQueueA2, buffer_num, L2_m * L2_k * sizeof(Tin)); // 65536÷2÷2=256*64
        pipe.InitBuffer(inQueueB2, buffer_num, L2_k * L2_n * sizeof(Tin)); // 65536÷2÷2=256*64

        // c size=262144
        pipe.InitBuffer(outQueueCO1, buffer_num, L2_m * L2_n * sizeof(Tout)); //(262144÷2)÷4÷2=256*64
        pipe.InitBuffer(outQueueCO2, buffer_num, L2_m * L2_n * sizeof(Tout)); //(262144÷2)÷4÷2=256*64
    }
    __aicore__ inline void Process()
    {
        //多核划分
        // int32_t start_group = this->process_id * this->group_per_core;
        // int32_t end_group = (this->process_id + 1) * this->group_per_core;
        // for (int group = start_group; group < this->group_num && group < end_group; group += 1)
        // {
        //     this->MatMul(group);
        // }
        // 组分给aicore
        for (int group = this->process_id; group < this->group_num; group += this->process_num)
        {
            this->MatMul(group);
        }
    }

private:
    __aicore__ inline void MatMul(int group)
    {   
        this->is_new_group = true;

        int k_split_max = this->CalcBlockNum(k, this->L1_k);
        for (int k_split_id = 0; k_split_id < k_split_max; k_split_id++)
        {
            this->Copy2L1inNZ(group, k_split_id);
            this->L2Operation();
        }
        this->Copyout(group);
    }

    __aicore__ inline void Copy2L1inNZ(int group, int k_split_id)
    {
        this->Copy2A1(group, k_split_id);
        this->Copy2B1(group, k_split_id);
    }

    __aicore__ inline void L2Operation()
    {   
        int L1_k_split_max = this->CalcBlockNum(this->L1_k, this->L2_k);
        int L1_group_split_max = this->CalcBlockNum(this->L1_k, this->L2_k);
        for (int L1_k_split_id = 0; L1_k_split_id < L1_k_split_max; L1_k_split_id++)
        {
            this->NZCopy2A2ZZ(L1_k_split_id);
            this->NZCopy2B2ZN(L1_k_split_id);
            this->Compute();
        }
        AscendC::LocalTensor<Tin> A1 = this->inQueueA1.template DeQue<Tin>();
        this->inQueueA1.template FreeTensor<Tin>(A1);
        AscendC::LocalTensor<Tin> B1 = this->inQueueB1.template DeQue<Tin>();
        this->inQueueB1.template FreeTensor<Tin>(B1);
    }

    // L1_k需要是16的倍数
    __aicore__ inline void Copy2A1(int group, int k_split_id)
    {
        AscendC::LocalTensor<Tin> A1 = this->inQueueA1.template AllocTensor<Tin>();

        AscendC::Nd2NzParams nd2nzA1Params;
        nd2nzA1Params.ndNum = 1;
        nd2nzA1Params.nValue = this->L1_m;
        nd2nzA1Params.dValue = this->L1_k;
        nd2nzA1Params.srcNdMatrixStride = 0;
        nd2nzA1Params.srcDValue = this->k;
        nd2nzA1Params.dstNzC0Stride = this->L1_m;
        nd2nzA1Params.dstNzNStride = 1;
        nd2nzA1Params.dstNzMatrixStride = 0;
        uint64_t global_offset = (group / this->b_group_num) * this->L1_m * this->k + k_split_id * this->L1_k;
        AscendC::DataCopy(A1, aGM[global_offset], nd2nzA1Params);

        // // 按列搬运
        // AscendC::DataCopyParams dataCopyParams;
        // dataCopyParams.blockCount = this->L1_m;
        // dataCopyParams.blockLen = 1;
        // dataCopyParams.srcStride = (this->k - CUBE_SIZE) / CUBE_SIZE;
        // dataCopyParams.dstStride = 0;
        // uint64_t global_offset = (group / this->b_group_num) * this->L1_m * this->k + k_split_id * this->L1_k;
        // for(int i = 0; i < this->CalcBlockNum(this->L1_k, CUBE_SIZE); i++){
        //     AscendC::DataCopy(A1[i * this->L1_m * CUBE_SIZE], aGM[global_offset], dataCopyParams);
        //     global_offset += CUBE_SIZE;
        // }

        // // 按行搬运
        // AscendC::DataCopyParams dataCopyParams;
        // dataCopyParams.blockCount = this->CalcBlockNum(this->L1_k, CUBE_SIZE);
        // dataCopyParams.blockLen = 1;
        // dataCopyParams.srcStride = 0;
        // dataCopyParams.dstStride = this->L1_m - 1;
        // uint64_t global_offset = (group / this->b_group_num) * this->L1_m * this->k + k_split_id * this->L1_k;
        // for(int i = 0; i < this->L1_m; i++){
        //     AscendC::DataCopy(A1[i * CUBE_SIZE], aGM[global_offset], dataCopyParams);
        //     global_offset += this->k;
        // }

        this->inQueueA1.template EnQue<Tin>(A1);
    }

    __aicore__ inline void Copy2B1(int group, int k_split_id)
    {
        AscendC::LocalTensor<Tin> B1 = this->inQueueB1.template AllocTensor<Tin>();

        AscendC::Nd2NzParams nd2nzB1Params;
        nd2nzB1Params.ndNum = 1;
        nd2nzB1Params.nValue = this->L1_k;
        nd2nzB1Params.dValue = this->L1_n;
        nd2nzB1Params.srcNdMatrixStride = 0;
        nd2nzB1Params.srcDValue = this->n;
        nd2nzB1Params.dstNzC0Stride = this->L1_k;
        nd2nzB1Params.dstNzNStride = 1;
        nd2nzB1Params.dstNzMatrixStride = 0;
        uint64_t global_offset = k_split_id * this->L1_k * this->n + (group % this->b_group_num) * this->L1_n;
        AscendC::DataCopy(B1, bGM[global_offset], nd2nzB1Params);

        // // 按列搬运
        // AscendC::DataCopyParams dataCopyParams;
        // dataCopyParams.blockCount = this->L1_k;
        // dataCopyParams.blockLen = 1;
        // dataCopyParams.srcStride = (this->n - CUBE_SIZE) / CUBE_SIZE;
        // dataCopyParams.dstStride = 0;
        // uint64_t global_offset = k_split_id * this->L1_k * this->n + (group % this->b_group_num) * this->L1_n;
        // for(int i = 0; i < this->CalcBlockNum(this->L1_n, CUBE_SIZE); i++){
        //     AscendC::DataCopy(B1[i * this->L1_k * CUBE_SIZE], bGM[global_offset], dataCopyParams);
        //     global_offset += CUBE_SIZE;
        // }

        //按行搬运
        // AscendC::DataCopyParams dataCopyParams;
        // dataCopyParams.blockCount = this->CalcBlockNum(this->L1_n, CUBE_SIZE);
        // dataCopyParams.blockLen = 1;
        // dataCopyParams.srcStride = 0;
        // dataCopyParams.dstStride = this->L1_k - 1;
        // uint64_t global_offset = k_split_id * this->L1_k * this->n + (group % this->b_group_num) * this->L1_n;
        // for(int i = 0; i < this->L1_k; i++){
        //     AscendC::DataCopy(B1[i * CUBE_SIZE], bGM[global_offset], dataCopyParams);
        //     global_offset += this->n;
        // }

        this->inQueueB1.template EnQue<Tin>(B1);
    }

    __aicore__ inline void NZCopy2A2ZZ(int L1_k_split_id)
    {
        AscendC::LocalTensor<Tin> A1 = this->inQueueA1.template DeQue<Tin>();
        AscendC::LocalTensor<Tin> A2 = this->inQueueA2.template AllocTensor<Tin>();

       // 按行搬运
        AscendC::LoadData2DParams loadDataParams;
        //一行分形矩阵重复次数，就是一行有多少个分形矩阵
        loadDataParams.repeatTimes = this->CalcBlockNum(this->L2_k, (CUBE_SIZE*2)/this->DT);
        //在nz格式中，前一个分行与后一个分形之间的地址偏移，单位为512B，即一个分形矩阵。
        loadDataParams.srcStride = this->CalcBlockNum(this->L1_m, CUBE_SIZE);
        // loadDataParams.srcStride = this->L1_m * ((CUBE_SIZE*2)/this->DT) / 512;
        loadDataParams.dstGap = 0;
        loadDataParams.ifTranspose = false;

        int src_start = L1_k_split_id * this->L2_k * this->L1_m;
        
        int row_cube_max = this->CalcBlockNum(this->L2_m, CUBE_SIZE);
        for (int i = 0; i < row_cube_max; i++)
        {
            AscendC::LoadData(A2[i * this->L2_k * CUBE_SIZE],
                    A1[src_start + i * CUBE_SIZE * (CUBE_SIZE*2)/this->DT], loadDataParams);
        }

        // //手动按列搬运
        // AscendC::LoadData2DParams loadDataParams;
        // //一行分形矩阵重复次数，就是一行有多少个分形矩阵
        // loadDataParams.repeatTimes = 1;
        // //在nz格式中，前一个分行与后一个分形之间的地址偏移，单位为512B，即一个分形矩阵。
        // loadDataParams.srcStride = 1;
        // loadDataParams.dstGap = 0;//不支持
        // loadDataParams.ifTranspose = false;

        // int src_start = L1_k_split_id * this->L2_k * this->L1_m;
        // int row_cube_max = this->CalcBlockNum(this->L2_k, CUBE_SIZE);
        // for (int i = 0; i < row_cube_max; i++)
        // {
        //     for(int j = 0; j < this->CalcBlockNum(this->L2_m, CUBE_SIZE); j++){
        //         AscendC::LoadData(A2[i * CUBE_SIZE * CUBE_SIZE + j * this->L2_k * CUBE_SIZE],
        //             A1[src_start + i * this->L1_m * CUBE_SIZE + j * CUBE_SIZE * CUBE_SIZE], loadDataParams);
        //     }
        // }

        this->inQueueA2.template EnQue<Tin>(A2);//L2缓存入队需要加类型模板,先入队A2，后入队A1，避免同步紊乱
        this->inQueueA1.template EnQue<Tin>(A1);
    }

    __aicore__ inline void NZCopy2B2ZN(int L1_k_split_id)
    {
        AscendC::LocalTensor<Tin> B1 = this->inQueueB1.template DeQue<Tin>();
        AscendC::LocalTensor<Tin> B2 = this->inQueueB2.template AllocTensor<Tin>();

        if constexpr (AscendC::Std::is_same<Tin,bfloat16_t>::value || AscendC::Std::is_same<Tin,half>::value){
            // AscendC::printf("int8_t not support\n");
            //按行搬运
            AscendC::LoadData2DParams loadDataParams;
            loadDataParams.repeatTimes = this->CalcBlockNum(this->L2_n, CUBE_SIZE);
            loadDataParams.srcStride = this->CalcBlockNum(this->L1_k, CUBE_SIZE);
            loadDataParams.dstGap = 0;
            loadDataParams.ifTranspose = true;

            int src_start = L1_k_split_id * this->L2_k * CUBE_SIZE;
            int row_cube_max = this->CalcBlockNum(this->L2_k, CUBE_SIZE);
            for (int i = 0; i < row_cube_max; i++)
            {
                AscendC::LoadData(B2[i * this->L1_n * CUBE_SIZE],
                        B1[src_start + i * CUBE_SIZE * CUBE_SIZE], loadDataParams);
            }
        }else if constexpr (AscendC::Std::is_same<Tin,int8_t>::value){
            // AscendC::printf("int8_t support yet\n");
            AscendC::LoadData2dTransposeParams loadDataParams;
            loadDataParams.repeatTimes = this->CalcBlockNum(this->L2_n, (CUBE_SIZE*2)/this->DT);
            loadDataParams.srcStride = this->CalcBlockNum(this->L1_k, (CUBE_SIZE*2)/this->DT);
            loadDataParams.dstGap = 1;
            loadDataParams.dstFracGap  = 0;

            int src_start = L1_k_split_id * this->L2_k * (CUBE_SIZE*2)/this->DT;
            int row_cube_max = this->CalcBlockNum(this->L2_k, (CUBE_SIZE*2)/this->DT);
            for (int i = 0; i < row_cube_max; i++)
            {
                AscendC::LoadDataWithTranspose(B2[i * this->L2_n * (CUBE_SIZE*2)/this->DT],
                        B1[src_start + i * (CUBE_SIZE*2)/this->DT * (CUBE_SIZE*2)/this->DT], loadDataParams);
            }
        }

        this->inQueueB2.template EnQue<Tin>(B2);//避免同步紊乱
        this->inQueueB1.template EnQue<Tin>(B1);
    }

    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<Tin> A2 = this->inQueueA2.template DeQue<Tin>();
        AscendC::LocalTensor<Tin> B2 = this->inQueueB2.template DeQue<Tin>();
        AscendC::LocalTensor<Tout> C1;
        if(this->is_new_group){
            C1 = this->outQueueCO1.template AllocTensor<Tout>();
        }
        else{
            C1 = this->outQueueCO1.template DeQue<Tout>();
        }
        
        AscendC::MmadParams mmadParams;
        mmadParams.m = this->L2_m;
        mmadParams.n = this->L2_n;
        mmadParams.k = this->L2_k;
        mmadParams.cmatrixInitVal = this->is_new_group;
        AscendC::Mmad<Tout,Tin,Tin>(C1, A2, B2, mmadParams);
        
        this->outQueueCO1.template EnQue<Tout>(C1);//先入队，后释放，避免同步紊乱
        this->inQueueA2.template FreeTensor<Tin>(A2);
        this->inQueueB2.template FreeTensor<Tin>(B2);

        this->is_new_group = false;
    }

    __aicore__ inline void Copyout(int group)
    {   
        this->fixpipe2GM(group);
    }

    __aicore__ inline void fixpipe2GM(int group)
    {   
        AscendC::LocalTensor<Tout> C1 = this->outQueueCO1.template DeQue<Tout>();
        AscendC::FixpipeParamsV220 fixpipeParams;
        fixpipeParams.nSize = this->L2_n;
        fixpipeParams.mSize = this->L2_m;
        fixpipeParams.srcStride = this->L2_m;
        fixpipeParams.dstStride = this->n;

        fixpipeParams.ndNum = 1;
        fixpipeParams.srcNdStride = 0;
        fixpipeParams.dstNdStride = 0;

        uint64_t global_offset = (group / this->b_group_num) * this->L1_m * this->n + 
                            (group % this->b_group_num) * this->L1_n;

        AscendC::Fixpipe(cGM[global_offset], C1, fixpipeParams);
        this->outQueueCO1.template FreeTensor<Tout>(C1);
    }

    __aicore__ inline int CalcBlockNum(int num, int unit_size)
    {
        return (num + unit_size - 1) / unit_size;
    }
};

__global__ __cube__ void gemm(__gm__ uint8_t *A, __gm__ uint8_t *B, __gm__ uint8_t *C, uint32_t m, uint32_t k, uint32_t n)
{
    // parallel impl
    // 初始化全局状态寄存器（在TPipe框架编程中，初始化过程由TPipe完成，无需开发者关注；静态Tensor编程方式中需要开发者手动调用）
    KernelMatmul<half,float> op;
    // TODO: tile方式通过策略模式传入参数，目前先写死
    op.Init(A, B, C, m, k, n, 64, 64, 64, 64, 64, 64, 1);
    op.Process();
}

extern "C" {
    void launch_gemm(aclrtStream stream, int numBlocks, uint8_t *A, uint8_t *B, uint8_t *C, uint32_t m, uint32_t k, uint32_t n)
    {
        gemm<<<numBlocks, nullptr, stream>>>(A, B, C, m, k, n);
    }
}